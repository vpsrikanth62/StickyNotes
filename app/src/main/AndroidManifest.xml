<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.stickynote">

    <application
        android:allowBackup="true"
        android:icon="@drawable/bg_widget_glass"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Widget Provider -->
        <receiver
            android:name=".StickyNoteWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/sticky_note_widget_info" />
        </receiver>

        <!-- Toggle checkbox broadcast receiver -->
        <receiver
            android:name=".WidgetActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.stickynote.TOGGLE_ITEM" />
            </intent-filter>
        </receiver>

        <!-- RemoteViews ListView service -->
        <service
            android:name=".NoteWidgetService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!-- Note editor activity -->
        <activity
            android:name=".EditNoteActivity"
            android:theme="@style/EditNoteTheme"
            android:exported="false"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <!-- Motivation overlay activity -->
        <activity
            android:name=".MotivationActivity"
            android:theme="@style/MotivationTheme"
            android:exported="false" />

    </application>
</manifest>
