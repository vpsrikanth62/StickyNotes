<?xml version="1.0" encoding="utf-8"?>
<!-- Editor screen: full glass card with RecyclerView bullets -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_editor_scrim">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:elevation="28dp">

        <!-- Gradient accent bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@drawable/bg_accent_gradient" />

        <!-- Card header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u2728 Sticky Notes"
                    android:textColor="#FFFFFFFF"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap circle to mark done"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- done/total badge -->
            <TextView
                android:id="@+id/tv_char_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/0"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_btn_cancel"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_divider_glass" />

        <!-- RecyclerView bullet list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="320dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_divider_glass" />

        <!-- Add item button -->
        <Button
            android:id="@+id/btn_add_item"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="+ Add bullet"
            android:textColor="#A855F7"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_divider_glass" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="20dp">

            <Button
                android:id="@+id/btn_cancel"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:text="Cancel"
                android:textColor="#80FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_btn_cancel"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginEnd="10dp" />

            <Button
                android:id="@+id/btn_save"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:text="Save Notes"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_btn_save"
                android:paddingStart="24dp"
                android:paddingEnd="24dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
