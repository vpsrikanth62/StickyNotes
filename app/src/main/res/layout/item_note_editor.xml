<?xml version="1.0" encoding="utf-8"?>
<!-- One row: constrained anchors so checkbox/text/delete stay perfectly aligned -->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_editor_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="50dp"
    android:background="@drawable/bg_editor_note_row"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="7dp"
    android:paddingBottom="7dp"
    android:layout_marginBottom="8dp">

    <EditText
        android:id="@+id/et_item_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/btn_delete_item"
        android:layout_centerVertical="true"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="8dp"
        android:background="@android:color/transparent"
        android:hint="Add a note..."
        android:textColorHint="#35FFFFFF"
        android:textColor="#F0FFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:inputType="textCapSentences"
        android:maxLines="1"
        android:imeOptions="actionNext"
        android:includeFontPadding="false"
        android:minHeight="28dp"
        android:gravity="center_vertical" />

    <ImageButton
        android:id="@+id/btn_delete_item"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="#80FFFFFF"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:contentDescription="delete" />

</RelativeLayout>
