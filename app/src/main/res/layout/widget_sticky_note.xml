<?xml version="1.0" encoding="utf-8"?>
<!--
    Liquid Glass Sticky Note Widget
    Android 16 Expressive Design Language
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_glass"
    android:padding="0dp">

    <!-- === TOP ACCENT BAR (gradient purple→pink) === -->
    <View
        android:id="@+id/accent_bar"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/bg_accent_gradient" />

    <!-- === HEADER ROW === -->
    <LinearLayout
        android:id="@+id/header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/accent_bar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- Sparkle / pin icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨"
            android:textSize="13sp"
            android:layout_marginEnd="6dp" />

        <!-- Title label -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NOTE"
            android:textColor="#B3FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.18" />

        <!-- Subtle right-side glyph -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="•••"
            android:textColor="#40FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.12" />
    </LinearLayout>

    <!-- === GLASS DIVIDER === -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/header_row"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_divider_glass" />

    <!-- === NOTE BODY === -->
    <!--
        IMPORTANT: Use wrap_content, NOT 0dp.
        In RelativeLayout, 0dp collapses to zero height and hides the text!
        layout_below + layout_above positions it correctly between header and footer.
    -->
    <TextView
        android:id="@+id/tv_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/divider_top"
        android:layout_above="@id/footer_row"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.5"
        android:gravity="top|start"
        android:ellipsize="end"
        android:maxLines="12"
        android:text="Tap to add a note..." />

    <!-- === FOOTER HINT ROW === -->
    <LinearLayout
        android:id="@+id/footer_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:paddingTop="6dp">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@drawable/bg_divider_glass" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  TAP TO EDIT  "
            android:textColor="#40FFFFFF"
            android:textSize="8sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@drawable/bg_divider_glass" />

    </LinearLayout>

</RelativeLayout>
