<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_glass"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/preview_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="5dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_title"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:maxLines="1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/widget_preview_progress"
                android:textColor="#8AFFFFFF"
                android:textSize="9sp"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"
                android:maxLines="1" />
        </LinearLayout>

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="6dp"
            android:background="@drawable/bg_widget_edit_btn"
            android:src="@drawable/ic_widget_edit"
            android:scaleType="centerInside"
            android:contentDescription="@string/widget_edit" />
    </LinearLayout>

    <TextView
        android:id="@+id/preview_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/preview_header"
        android:background="@drawable/bg_divider_glass"
        android:text="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/preview_divider"
        android:orientation="vertical"
        android:paddingTop="6dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:background="@drawable/bg_widget_row_chip"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="@string/widget_preview_item_1"
            android:textColor="#F2FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:maxLines="2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:background="@drawable/bg_widget_row_chip"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="@string/widget_preview_item_2"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:maxLines="2" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_widget_row_chip"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="@string/widget_preview_item_3"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:maxLines="2" />
    </LinearLayout>
</RelativeLayout>
