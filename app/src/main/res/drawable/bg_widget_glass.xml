<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#EE0F1220"
                android:centerColor="#E816142B"
                android:endColor="#E01E0F38"
                android:angle="145"
                android:type="linear" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#30FFFFFF"
                android:centerColor="#10FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <!-- Border inset keeps rounded corners visible on launcher clipping -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="#5CFFFFFF" />
            <corners android:radius="21dp" />
        </shape>
    </item>

</layer-list>
