<?xml version="1.0" encoding="utf-8"?>
<!-- Empty circle checkbox: unchecked state.
     Uses two 180° arcs (standard trick — VectorDrawable has no <circle> element) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Full circle ring: M left-edge, arc right-edge, arc back -->
    <path
        android:pathData="M2,12 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0"
        android:strokeWidth="1.8"
        android:strokeColor="#65FFFFFF"
        android:fillColor="#18FFFFFF" />

</vector>
