<?xml version="1.0" encoding="utf-8"?>
<!--
    Floating glass card for editor.
    Bigger corner radius (32dp) for Android 16 expressive feel.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Frosted glass base -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#D90E1022"
                android:endColor="#D9180930"
                android:angle="150"
                android:type="linear" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <!-- Top-left catch-light shimmer -->
    <item
        android:bottom="60%"
        android:right="30%">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#22FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <!-- Glass border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="#3DFFFFFF" />
            <corners android:radius="32dp" />
        </shape>
    </item>

</layer-list>
